// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  phone        String?       @unique
  email        String?       @unique
  fullName     String?
  dateOfBirth  DateTime?
  address      String?
  profilePhoto String?
  authProvider String      // "google" | "apple" | "phone"
  createdAt    DateTime      @default(now())
  profile      RiderProfile?
  appState     RiderAppState?
  policies     Policy[]
}

model RiderProfile {
  id                       String   @id @default(uuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id])
  platform                 String   // "zepto" | "blinkit"
  city                     String?
  serviceZone              String   // e.g. "Bengaluru-Koramangala"
  avgDailyIncome           Float
  workingHours             Int?
  workingShiftLabel        String?
  workingTimeSlots         String[] @default([])
  weeklyWorkDays           Int      @default(6)
  zoneRiskScore            Float    @default(0.3)  // seeded from zone history
  platformConnectionStatus String   @default("not_connected") // "not_connected" | "verified" | "not_found"
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model RiderAppState {
  id                     String      @id @default(uuid())
  userId                 String      @unique
  user                   User        @relation(fields: [userId], references: [id])
  flagCount              Int         @default(0)
  currentFlagLevel       String      @default("none")
  currentReasons         String[]    @default([])
  currentStatusText      String      @default("GPS check inactive")
  lastCheckedAt          DateTime?
  redFlagDetectedAt      DateTime?
  normalizedAfterRedAt   DateTime?
  outOfStationActive     Boolean     @default(false)
  outOfStationSince      DateTime?
  outOfStationUntil      DateTime?
  outOfStationReturnLabel String?
  appBackToNormalAt      DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  flagEvents             FlagEvent[]
}

model FlagEvent {
  id         String        @id @default(uuid())
  appStateId String
  appState   RiderAppState @relation(fields: [appStateId], references: [id])
  reason     String
  detectedAt DateTime
  createdAt  DateTime      @default(now())

  @@unique([appStateId, reason, detectedAt])
  @@index([appStateId, detectedAt])
}

model Policy {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  status          String   // "active" | "expired" | "pending_payment"
  weekStartDate   DateTime
  weekEndDate     DateTime
  coveragePerDay  Float
  weeklyPremium   Float
  riskSnapshot    Json     // { F, Z, A, composite } at time of purchase
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  claims          Claim[]
}

model Claim {
  id             String   @id @default(uuid())
  policyId       String
  policy         Policy   @relation(fields: [policyId], references: [id])
  triggerType    String   // "rain" | "app_outage" | "zone_closure"
  affectedSlots  Json     // ["S3", "S4"]
  disruptedHours Float
  payoutAmount   Float
  status         String   // "auto_approved" | "pending_review" | "paid"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DisruptionEvent {
  id          String   @id @default(uuid())
  zone        String
  triggerType String
  startTime   DateTime
  endTime     DateTime?
  dataSnapshot Json    // raw API response that triggered it
}
